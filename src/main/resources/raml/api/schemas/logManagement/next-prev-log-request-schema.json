{
	"title": "next or previous log chunk",
	"$schema": "http://json-schema.org/draft-04/schema#",
	"javaType": "com.sos.joc.model.log.KeyedLogRequest",
	"type": "object",
	"required": [
	    "key",
	    "logToken"
	],
	"properties": {
		"key": {
            "type": "string",
            "minLength": 3,
            "pattern": "^[0-9]+(?:[.][0-9]+)?/[0-9]+$"
        },
        "logToken": {
            "type": "string",
            "pattern": "[0-9a-f-]+",
            "minLength": 36,
            "maxLength": 36
        },
        "limit": {
            "$ref": "../common/nonNegativeLong-schema.json"
        }
	},
    "additionalProperties": false
}

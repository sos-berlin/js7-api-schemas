{
	"title": "running log filter",
	"$schema": "http://json-schema.org/draft-04/schema#",
	"javaType": "com.sos.joc.model.log.RunningLogRequest",
	"type": "object",
	"required": [
	    "logToken"
	],
	"properties": {
		"logToken": {
            "type": "string",
            "pattern": "[0-9a-f-]+",
            "minLength": 36,
            "maxLength": 36
        }
	},
    "additionalProperties": false
}

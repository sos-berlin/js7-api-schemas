{
	"title": "running log filter",
	"$schema": "http://json-schema.org/draft-04/schema#",
	"javaType": "com.sos.joc.model.log.RunningLogRequest",
	"type": "object",
	"extends" : {
        "$ref": "next-log-request-schema.json"
    },
	"required": [
        "key",
        "logToken"
    ],
	"properties": {
		"timeout": {
		    "description": "the result is sent when the 'timeout' (in seconds) or the 'limit' is reached.",
            "type": "integer",
            "minimum": 1,
            "maximum": 57,
            "default": 57
        }
	},
    "additionalProperties": false
}

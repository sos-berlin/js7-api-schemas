{
	"title": "log base filter",
	"$schema": "http://json-schema.org/draft-04/schema#",
	"javaType": "com.sos.joc.model.log.LogBaseRequest",
	"type": "object",
	"required": [
	    "controllerId",
	    "dateFrom"
	],
	"properties": {
		"controllerId": {
            "$ref": "../common/controllerIdRequired-schema.json"
        },
        "level": {
            "javaType": "com.sos.joc.model.log.RequestLevel",
            "type": "string",
            "enum": [
                "ERROR",
                "INFO",
                "DEBUG"
            ],
            "default": "INFO"
        },
        "dateFrom": {
			"$ref": "../common/dateFromTo-schema.json"
		},
		"dateTo": {
			"$ref": "../common/dateFromTo-schema.json"
		},
		"timeZone": {
			"$ref": "../common/timezone-schema.json"
		},
		"numOfLines": {
			"type": "number",
            "format": "utc-millisec"
		}
	},
    "additionalProperties": false
}

{
	"title": "log response",
	"$schema": "http://json-schema.org/draft-04/schema#",
	"javaType": "com.sos.joc.model.log.LogResponse",
	"type": "object",
	"required": [
	    "logLines",
	    "timeZone",
	    "token",
	    "isComplete"
	],
    "properties": {
        "logLines": {
            "type": "array",
            "items": {
                "type": "object",
                "javaType": "com.sos.joc.model.log.LogLine",
                "properties": {
                    "key": {
                        "$ref": "../common/string100-schema.json"
                    },
                    "line": {
                        "type": "string"
                    } 
                },
                "additionalProperties": false
            }
        },
        "timeZone": {
			"$ref": "../common/timezone-schema.json"
		},
		"logToken": {
			"type": "string",
			"pattern": "[0-9a-f-]+",
			"minLength": 36,
			"maxLength": 36
		},
        "dateToReached": {
            "description": "Is true if 'dateTo' is reached",
            "type": "boolean"
        },
        "numOfLinesReached": {
            "description": "Is true if 'numOfLines' is reached",
            "type": "boolean"
        },
        "lastLogLineReached": {
            "description": "Is sent with ./log and ./log/next api if currently no more further log lines are available but neither 'dateTo' nor 'numOfLines' are reached",
            "type": "boolean"
        },
        "firstLogLineReached": {
            "description": "It sent with ./log/prev api if the first line from the 'dateTo' parameter is reached",
            "type": "boolean"
        }
        
	},
    "additionalProperties": false
}

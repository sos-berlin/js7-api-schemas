{
  "title": "compact Filter For The Deployment History",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "javaType": "com.sos.joc.model.publish.DepHistoryCompactFilter",
  "type": "object",
  "properties": {
    "account": {
      "$ref": "../common/string255-schema.json"
    },
    "folder": {
      "$ref": "../common/path-schema.json"
    },
    "controllerId": {
      "$ref": "../common/controllerId-schema.json"
    },
    "deployType" : {
      "$ref": "../inventory/common/configurationTypeDeployables-schema.json"
    },
    "operation" : {
      "$ref": "operationType-schema.json"
    },
    "state" : {
      "$ref": "deploymentState-schema.json"
    },
    "deploymentDate": {
      "$ref": "../common/timestamp-schema.json"
    },
    "deleteDate": {
      "$ref": "../common/timestamp-schema.json"
    },
    "from": {
      "$ref": "../common/dateFromTo-schema.json"
    },
    "to": {
      "$ref": "../common/dateFromTo-schema.json"
    },
    "timeZone": {
      "$ref": "../common/timezone-schema.json"
    }, 
    "limit": {
        "description": "Limits the number of resulting items; -1=unlimited",
        "type": "integer",
        "default": 5000
    }
  }
}
